{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Ensure virtual environment",
            "type": "shell",
            "command": "python -c \"import sys; print('Running in venv' if sys.prefix != sys.base_prefix else sys.exit(1))\"",
            "detail": "Verify that the Python execution is inside a virtual environment before running Streamlit.",
            "problemMatcher": []
        },
        {
            "label": "Run Streamlit App",
            "type": "shell",
            "command": "./.venv/Scripts/python",
            "args": [
                "run.py"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}